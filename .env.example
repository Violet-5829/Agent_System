# LLM
OPENAI_API_KEY=sk-your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# SkillHub (optional)
SKILLHUB_API_KEY=
SKILLHUB_BASE_URL=
SKILLHUB_TIMEOUT_SECONDS=15

# 分析数据
EXCEL_DATA_ROOT=./backend/data/excel_inbox
SQL_DEFAULT_STATEMENT_TIMEOUT_SECONDS=30
SQL_MAX_ROWS=5000

# Artifacts 公开 URL（前端访问图表/报表）
ARTIFACT_PUBLIC_BASE_URL=http://127.0.0.1:8011/artifacts

# Agent Playground
AGENT_PLAYGROUND_APP_HOME=./backend/data
AGENT_PLAYGROUND_BUNDLED_SKILLS_ROOT=./backend/skills
AGENT_PLAYGROUND_ENV_PATH=./.env
